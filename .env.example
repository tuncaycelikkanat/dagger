APP_NAME=DAGGER
APP_ENV=development
APP_DEBUG=true
API_PREFIX=/api/v1

LOG_LEVEL=INFO

UPLOAD_DIR=storage/uploads
METADATA_DIR=storage/metadata
PROCESSED_DIR=storage/processed

MAX_UPLOAD_SIZE_MB=25

CHUNK_SIZE=1200
CHUNK_OVERLAP=200

DEFAULT_LLM_PROVIDER=mock

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT_SECONDS=120

OLLAMA_MODEL_DEFAULT=qwen2.5:3b
OLLAMA_MODEL_GRAPH_LIBRARIAN=bge-m3
OLLAMA_MODEL_ARCHITECT=qwen2.5:3b
OLLAMA_MODEL_VISION=qwen2.5-vl
OLLAMA_MODEL_SANITIZER=phi3.5
OLLAMA_MODEL_CODER=qwen2.5-coder:7b
OLLAMA_MODEL_CRITIC=qwen2.5:3b
OLLAMA_MODEL_AUDITOR=qwen2.5:3b

DEFAULT_LLM_PROVIDER=ollama
OLLAMA_MODEL_DEFAULT=qwen2.5:3b
OLLAMA_MODEL_ARCHITECT=qwen2.5:3b
OLLAMA_MODEL_AUDITOR=qwen2.5:3b
OLLAMA_MODEL_CRITIC=qwen2.5:3b